{
  "color": {
    "background": ["#fafafa"],
    "foreground": ["#131313"],
    "accent": ["#0054f9"],
    "muted": ["#6b7280", "#e5e7eb", "#e8edf3"],
    "hero_overlay": [
      "rgba(75,130,185,0.7)",
      "rgba(75,130,185,0.5)",
      "rgba(75,130,185,0.2)"
    ],
    "card_surface": "bg-white/85",
    "card_border": "border-white/50"
  },
  "typography": {
    "display_family": "var(--font-cormorant)",
    "body_family": "var(--font-roboto)",
    "display_scale": ["clamp(2.5rem, 5vw, 4.5rem)"],
    "body_scale": ["0.75rem", "0.875rem", "1rem", "1.125rem"],
    "display_leading": "1.1",
    "tracking": {
      "display": "-0.04em",
      "eyebrow": "0.08rem"
    },
    "display_emphasis": "italic on single words (<em>)"
  },
  "spacing": {
    "section_hero": "h-screen p-3",
    "container": "max-w-[80rem]",
    "gutter": ["px-6", "md:px-[3.25rem]"],
    "content_gap": ["mt-5", "mt-8", "mt-10", "mt-16"],
    "radius_card": "1.5rem",
    "radius_frame": "32px",
    "radius_pill": "full"
  },
  "motion": {
    "signature_springs": ["gentle", "snappy"],
    "entry_distance_y": [16, 80],
    "stagger_delay_ms": [100, 200, 300, 400, 500],
    "interaction_hover": "y: -1",
    "interaction_tap": "scale: 0.98"
  },
  "layout": {
    "hero_composition": "center-stack-text + fan-spread-cards",
    "card_rotation_pattern": [-8, 0, 8],
    "z_order": { "center_card": 20, "side_cards": 10 }
  }
}
